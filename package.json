{
  "name": "automacao-mobile-native-demo-app",
  "version": "1.0.0",
  "description": "Automação de testes mobile (Android/iOS) do native-demo-app com WebdriverIO + Appium",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test:android": "wdio run ./config/wdio.android.app.conf.js",
    "test:ios": "wdio run ./config/wdio.ios.app.conf.js",
    "test:android:bstack": "wdio run ./config/browserstack/wdio.android.bs.app.conf.js",
    "test:ios:bstack": "wdio run ./config/browserstack/wdio.ios.bs.app.conf.js",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "devDependencies": {
    "@wdio/allure-reporter": "^9.22.0",
    "@wdio/appium-service": "^9.22.0",
    "@wdio/browserstack-service": "^9.22.0",
    "@wdio/cli": "^9.22.0",
    "@wdio/local-runner": "^9.22.0",
    "@wdio/mocha-framework": "^9.22.0",
    "@wdio/spec-reporter": "^9.22.0",
    "allure-commandline": "^2.32.0",
    "appium": "^3.1.2",
    "appium-uiautomator2-driver": "^6.7.6",
    "appium-xcuitest-driver": "^10.13.2",
    "chai": "^4.4.1",
    "csv-parse": "^5.5.6"
  }
}
